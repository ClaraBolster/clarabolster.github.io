---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {% for page in site.pages %}{% if page.url contains '.xml' or page.url contains '.txt' or page.url contains '/assets/' %}{% continue %}{% endif %}
  <url>
    <loc>{{ site.data.config.site_url }}{{ page.url | replace: 'index.html', '' }}</loc>
    {% if page.lang == 'fr' %}
    {% assign alt_url = page.url | replace: '/fr/', '/' %}
    <xhtml:link rel="alternate" hreflang="en" href="{{ site.data.config.site_url }}{{ alt_url | replace: 'index.html', '' }}" />
    <xhtml:link rel="alternate" hreflang="fr" href="{{ site.data.config.site_url }}{{ page.url | replace: 'index.html', '' }}" />
    {% elsif page.lang == 'en' %}
    <xhtml:link rel="alternate" hreflang="en" href="{{ site.data.config.site_url }}{{ page.url | replace: 'index.html', '' }}" />
    <xhtml:link rel="alternate" hreflang="fr" href="{{ site.data.config.site_url }}/fr{{ page.url | replace: 'index.html', '' }}" />
    {% endif %}
  </url>
  {% endfor %}
</urlset>
